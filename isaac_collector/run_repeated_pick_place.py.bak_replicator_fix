        stage = open_usd_stage(args.scene_usd, simulation_app, wait=120)

        rgbd_recorder = None

        if args.enable_rgbd_recording:
            from isaac_collector.runtime.rgbd_multi_camera_recorder import (
                MultiCameraRGBDRecorder,
                create_table_camera,
                set_camera_local_transform,
            )

            camera_paths = []

            if args.use_table_camera:
                create_table_camera(
                    stage,
                    camera_path=args.table_camera_path,
                    eye=args.table_camera_eye,
                    target=args.table_camera_target,
                )
                camera_paths.append(args.table_camera_path)

            if args.use_wrist_cameras:
                # These local transforms are initial guesses.
                # You should tune them once in GUI if the wrist images face the wrong direction.
                set_camera_local_transform(
                    stage,
                    args.right_wrist_camera_path,
                    translate=(0.06, 0.0, 0.02),
                    rotate_xyz_deg=(0.0, 90.0, 0.0),
                )
                set_camera_local_transform(
                    stage,
                    args.left_wrist_camera_path,
                    translate=(0.06, 0.0, 0.02),
                    rotate_xyz_deg=(0.0, 90.0, 0.0),
                )
                camera_paths.extend([
                    args.right_wrist_camera_path,
                    args.left_wrist_camera_path,
                ])

            if not camera_paths:
                raise ValueError(
                    "--enable-rgbd-recording requires --use-table-camera "
                    "and/or --use-wrist-cameras"
                )

            print("[RGBD_INIT] camera_paths:", camera_paths, flush=True)
            print("[RGBD_INIT] output_dir:", Path(args.output_dir).expanduser().resolve(), flush=True)
            print("[RGBD_INIT] resolution:", args.rgbd_width, args.rgbd_height, flush=True)

            try:
                rgbd_recorder = MultiCameraRGBDRecorder(
                    stage=stage,
                    camera_paths=camera_paths,
                    output_dir=Path(args.output_dir).expanduser().resolve(),
                    width=args.rgbd_width,
                    height=args.rgbd_height,
                )
            except Exception as e:
                import traceback
                print("[RGBD_INIT][ERROR] MultiCameraRGBDRecorder init failed:", repr(e), flush=True)
                traceback.print_exc()
                raise

        robot_path = "/World/A2D"

        if not args.disable_bringup_teleport:
            move_a2d_close_to_cup_for_bringup(
                stage=stage,
                simulation_app=simulation_app,
                robot_path=robot_path,
            )
        else:
            print("[BRINGUP] disabled runtime A2D teleport; using USD robot pose", flush=True)

        print("[2] Start persistent GraspNet service", flush=True)
        grasp_service = PersistentJsonService(
            name="graspnet",
            python_exe=args.graspnet_python,
            worker_file=str(project_root / "isaac_collector/services/graspnet_service.py"),
            project_root=str(project_root),
            args=[
                "--mode",
                args.grasp_mode,
                *([] if args.graspnet_checkpoint is None else ["--checkpoint", args.graspnet_checkpoint]),
            ],
        )

        print("[3] Start persistent cuRobo service", flush=True)
        curobo_service = PersistentJsonService(
            name="curobo",
            python_exe=args.curobo_python,
            worker_file=str(project_root / "isaac_collector/services/curobo_service.py"),
            project_root=str(project_root),
            args=[
                "--mode",
                args.curobo_mode,
                *([] if args.curobo_robot_config is None else ["--robot-config", args.curobo_robot_config]),
            ],
        )

        output_dir = Path(args.output_dir).expanduser().resolve()
        output_dir.mkdir(parents=True, exist_ok=True)

        robot_state = load_retract_robot_state(args.curobo_robot_config)
        if args.curobo_mode == "real":
            print("[STATE] using cuRobo retract_config robot_state", flush=True)
            print("[STATE] robot_state joint_names:", robot_state.get("joint_names", []), flush=True)
            print("[STATE] robot_state positions:", robot_state.get("positions", []), flush=True)

        replay_controller = None
        if args.execution_mode == "a2d_replay":
            replay_controller = init_a2d_replay_controller(
                stage=stage,
                simulation_app=simulation_app,
                robot_path=robot_path,
                curobo_joint_names=robot_state.get("joint_names", []),
            )

        robot_world = get_prim_world_matrix(stage, robot_path)

        initial_robot_world = np.asarray(robot_world, dtype=float).copy()
        initial_cup_world = np.asarray(get_prim_world_matrix(stage, args.cup_path), dtype=float).copy()

        print("[DEBUG] world pose check", flush=True)
        for debug_path in [robot_path, args.cup_path, args.ee_path]:
            try:
                m = get_prim_world_matrix(stage, debug_path)
                print(f"[DEBUG] {debug_path}", flush=True)
                print(m, flush=True)
                print(
                    "[DEBUG] translation row:",
                    [float(m[3][0]), float(m[3][1]), float(m[3][2])],
                    flush=True,
                )
            except Exception as e:
                print(f"[DEBUG] failed to get pose for {debug_path}: {e!r}", flush=True)

        print("[DEBUG] robot_world matrix:", flush=True)
        print(robot_world, flush=True)

        print("[TARGET] configured pickup-target-robot:", args.pickup_target_robot, flush=True)
        print("[TARGET] configured place-target-robot:", args.place_target_robot, flush=True)

        print("[4] Start repeated pickup / move-right / putdown loop", flush=True)

        for ep in range(args.num_pick_place):
            from isaac_collector.runtime.load_scene import set_prim_world_matrix

            print("[RESET] reset robot, joints, and cup pose for new episode", flush=True)

            set_prim_world_matrix(stage, robot_path, initial_robot_world)
            set_prim_world_matrix(stage, args.cup_path, initial_cup_world)

            wait_frames(simulation_app, 10)

            if args.execution_mode == "a2d_replay":
                reset_a2d_joints_to_robot_state(
                    simulation_app=simulation_app,
                    replay_controller=replay_controller,
                    robot_state=robot_state,
                    hold_frames=60,
                )

            wait_frames(simulation_app, 20)

            print("\n" + "=" * 80, flush=True)
            print(f"[EP {ep + 1}/{args.num_pick_place}]", flush=True)
            print("=" * 80, flush=True)

            cup_offset = None

            cup_pose = get_prim_world_matrix(stage, args.cup_path)
            initial_cup_pose = np.asarray(cup_pose, dtype=float).copy()
            print("[STATE] cup pose:", flush=True)
            print(cup_pose, flush=True)

            obs_path = output_dir / f"ep_{ep:04d}_observation.npz"

            if args.observation_source == "synthetic":
                save_synthetic_observation_npz(
                    obs_path,
                    cup_pose_world=cup_pose,
                )
                print("[OBS] saved synthetic observation_npz:", obs_path, flush=True)

            elif args.observation_source == "rgbd_file":
                save_observation_from_existing_rgbd_npz(
                    src_npz_path=args.rgbd_observation_npz,
                    dst_npz_path=obs_path,
                )
                print("[OBS] saved RGB-D observation_npz:", obs_path, flush=True)

            else:
                raise ValueError(f"Unknown observation_source: {args.observation_source}")

            grasp_result = grasp_service.call(
                "predict",
                {
                    "object_path": args.cup_path,
                    "object_pose_world": cup_pose.tolist(),
                    "observation_npz": str(obs_path),
                },
            )

            save_json(output_dir / f"ep_{ep:04d}_grasp.json", grasp_result)
            print("[DEBUG] saved grasp json", flush=True)
            print("[DEBUG] grasp source:", grasp_result.get("source"), flush=True)

            lift_world = np.asarray(grasp_result.get("lift_pose_world", cup_pose), dtype=float)

            place_target_robot_precomputed = None

            if args.target_source == "manual":
                pickup_target_robot = make_robot_frame_target_matrix(
                    lift_world,
                    robot_world,
                    fixed_orientation=True,
                    clamp_to_known_reachable=True,
                )

                pickup_target_robot = override_robot_frame_target_translation(
                    pickup_target_robot,
                    args.pickup_target_robot,
                    name="pickup",
                )

            elif args.target_source == "cup_auto":
                pickup_z = (
                    float(args.pickup_target_z)
                    if args.pickup_target_z is not None
                    else float(args.pickup_target_robot[2])
                )
                place_z = (
                    float(args.place_target_z)
                    if args.place_target_z is not None
                    else float(args.place_target_robot[2])
                )

                pickup_target_robot, place_target_robot_precomputed = make_auto_targets_from_cup_pose(
                    cup_pose_world=cup_pose,
                    robot_world=robot_world,
                    place_offset_robot=args.place_offset_robot,
                    pickup_z=pickup_z,
                    place_z=place_z,
                )

            elif args.target_source == "graspnet":
                pickup_target_robot, place_target_robot_precomputed = make_targets_from_graspnet_result(
                    grasp_result=grasp_result,
                    robot_world=robot_world,
                    preferred_key=args.graspnet_target_key,
                    place_offset_robot=args.place_offset_robot,
                    pickup_target_z=args.pickup_target_z,
                    place_target_z=args.place_target_z,
                )

            else:
                raise ValueError(f"Unknown target_source: {args.target_source}")

            print("[DEBUG] pickup target robot-frame matrix:", flush=True)
            print(pickup_target_robot, flush=True)

            pickup_plan = curobo_service.call(
                "plan",
                {
                    "task": "pickup",
                    "robot_state": robot_state,
                    "waypoints_world": [pickup_target_robot.tolist()],
                },
            )

            print_plan_summary("pickup", pickup_plan)
            save_json(output_dir / f"ep_{ep:04d}_pickup_plan.json", pickup_plan)

            print("[EXEC] pickup: approach -> close gripper -> lift", flush=True)

            if args.execution_mode == "debug_object":
                execute_cartesian_debug_on_object(
                    simulation_app=simulation_app,
                    stage=stage,
                    cup_path=args.cup_path,
                    target_pose_world=lift_world,
                    frames=args.frames_per_segment,
                )

            elif args.execution_mode == "a2d_replay":
                pickup_executed = execute_curobo_plan_on_a2d(
                    simulation_app=simulation_app,
                    replay_controller=replay_controller,
                    plan=pickup_plan,
                    name="pickup",
                    steps_per_position=args.steps_per_position,
                    speed_stride=args.speed_stride,
                    stage=stage if (args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    cup_path=args.cup_path if (args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    ee_path=args.ee_path if (args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    save_stride=args.trajectory_save_stride,
                    rgbd_recorder=rgbd_recorder if args.enable_rgbd_recording else None,
                    ep=ep,
                    rgbd_record_stride=args.rgbd_record_stride,
                )

            else:
                raise ValueError(args.execution_mode)

            wait_frames(simulation_app, 20)

            if args.execution_mode == "a2d_replay" and args.attach_cup_during_place:
                cup_offset = compute_cup_to_ee_translation_offset(
                    stage,
                    replay_controller,
                    cup_path=args.cup_path,
                    ee_path=args.ee_path,
                )
                print("[ATTACH] cup attached to EE for place replay", flush=True)

            current_after_lift = get_prim_world_matrix(stage, args.cup_path)
            place_world = make_place_pose(
                current_after_lift,
                axis=args.right_axis,
                distance=args.right_distance,
            )

            if args.target_source in ("cup_auto", "graspnet"):
                if place_target_robot_precomputed is None:
                    raise RuntimeError(
                        f"target_source={args.target_source} but no precomputed place target"
                    )
                place_target_robot = place_target_robot_precomputed
                print(f"[TARGET] using precomputed {args.target_source} place target:", flush=True)
                print(place_target_robot, flush=True)

            else:
                place_target_robot = make_robot_frame_target_matrix(
                    place_world,
                    robot_world,
                    fixed_orientation=True,
                    clamp_to_known_reachable=True,
                )

                place_target_robot = override_robot_frame_target_translation(
                    place_target_robot,
                    args.place_target_robot,
                    name="place",
                )

            print("[DEBUG] place target robot-frame matrix:", flush=True)
            print(place_target_robot, flush=True)

            place_plan = curobo_service.call(
                "plan",
                {
                    "task": "putdown",
                    "robot_state": robot_state,
                    "world_collision": {},
                    "attached_object": args.cup_path,
                    "waypoints_world": [place_target_robot.tolist()],
                },
            )

            print_plan_summary("place", place_plan)
            save_json(output_dir / f"ep_{ep:04d}_place_plan.json", place_plan)

            print("[EXEC] move-right -> putdown -> open gripper", flush=True)

            if args.execution_mode == "debug_object":
                execute_cartesian_debug_on_object(
                    simulation_app=simulation_app,
                    stage=stage,
                    cup_path=args.cup_path,
                    target_pose_world=place_world,
                    frames=args.frames_per_segment,
                )

            elif args.execution_mode == "a2d_replay":
                place_executed = execute_curobo_plan_on_a2d(
                    simulation_app=simulation_app,
                    replay_controller=replay_controller,
                    plan=place_plan,
                    name="place",
                    steps_per_position=args.steps_per_position,
                    speed_stride=args.speed_stride,
                    stage=stage if (args.attach_cup_during_place or args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    cup_path=args.cup_path if (args.attach_cup_during_place or args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    ee_path=args.ee_path if (args.attach_cup_during_place or args.save_executed_trajectory or args.enable_rgbd_recording) else None,
                    cup_offset=cup_offset if args.attach_cup_during_place else None,
                    save_stride=args.trajectory_save_stride,
                    rgbd_recorder=rgbd_recorder if args.enable_rgbd_recording else None,
                    ep=ep,
                    rgbd_record_stride=args.rgbd_record_stride,
                )

            else:
                raise ValueError(args.execution_mode)

            wait_frames(simulation_app, 30)

            if args.attach_cup_during_place:
                final_cup_pose = get_prim_world_matrix(stage, args.cup_path)
                print("[ATTACH] final cup pose after place replay:", flush=True)
                print(final_cup_pose, flush=True)

            trajectory_files = {}

            if args.save_executed_trajectory and args.execution_mode == "a2d_replay":
                pickup_traj_path = output_dir / f"ep_{ep:04d}_pickup_executed_trajectory.json"
                place_traj_path = output_dir / f"ep_{ep:04d}_place_executed_trajectory.json"

                save_json(pickup_traj_path, pickup_executed)
                save_json(place_traj_path, place_executed)

                trajectory_files["pickup_executed"] = str(pickup_traj_path)
                trajectory_files["place_executed"] = str(place_traj_path)

                print(f"[SAVE] pickup executed trajectory: {pickup_traj_path}", flush=True)
                print(f"[SAVE] place executed trajectory: {place_traj_path}", flush=True)

            final_cup_pose_for_result = get_prim_world_matrix(stage, args.cup_path)

            episode_result = save_episode_result(
                output_dir=output_dir,
                ep=ep,
                args=args,
                initial_cup_pose=initial_cup_pose,
                final_cup_pose=final_cup_pose_for_result,
                pickup_plan=pickup_plan,
                place_plan=place_plan,
                pickup_target_robot=pickup_target_robot,
                place_target_robot=place_target_robot,
                trajectory_files=trajectory_files,
            )

            print(f"[EP {ep + 1}] done", flush=True)

        save_collection_summary(output_dir)

        print("[DONE] repeated pick-place collection loop finished.", flush=True)

        if args.keep_open and not args.headless:
            print("[INFO] keep-open enabled.", flush=True)
            while simulation_app.is_running():
                simulation_app.update()

    finally:
        if grasp_service is not None:
            grasp_service.close()
        if curobo_service is not None:
            curobo_service.close()
        simulation_app.close()


if __name__ == "__main__":
    main()