def validate_episode_basic(
    *,
    initial_cup_pose,
    final_cup_pose,
    min_move_distance: float = 0.03,
    min_final_z: float = 0.55,
    table_x_min: float = 2.5,
    table_x_max: float = 3.2,
    table_y_min: float = -2.1,
    table_y_max: float = -1.6,
) -> dict:
    initial_xyz = np.asarray(initial_cup_pose, dtype=float)[3, 0:3]
    final_xyz = np.asarray(final_cup_pose, dtype=float)[3, 0:3]

    move_distance = float(np.linalg.norm(final_xyz - initial_xyz))

    x, y, z = [float(v) for v in final_xyz.tolist()]

    checks = {
        "initial_xyz": [float(v) for v in initial_xyz.tolist()],
        "final_xyz": [float(v) for v in final_xyz.tolist()],
        "move_distance": move_distance,
        "min_move_distance": float(min_move_distance),
        "min_final_z": float(min_final_z),
        "moved_enough": bool(move_distance >= min_move_distance),
        "final_z_ok": bool(z >= min_final_z),
        "table_region": {
            "x_min": float(table_x_min),
            "x_max": float(table_x_max),
            "y_min": float(table_y_min),
            "y_max": float(table_y_max),
        },
        "final_xy_on_table_region": bool(
            table_x_min <= x <= table_x_max
            and table_y_min <= y <= table_y_max
        ),
    }

    checks["success"] = bool(
        checks["moved_enough"]
        and checks["final_z_ok"]
        and checks["final_xy_on_table_region"]
    )

    return checks

