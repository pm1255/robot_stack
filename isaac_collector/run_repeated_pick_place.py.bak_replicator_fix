def save_json(path: Path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2), encoding="utf-8")

def matrix_to_list(x):
    return np.asarray(x, dtype=float).tolist()


def pose_translation_from_matrix(x):
    m = np.asarray(x, dtype=float)
    return [float(m[3, 0]), float(m[3, 1]), float(m[3, 2])]


def safe_plan_success(plan: dict) -> bool:
    return bool(plan.get("success", False))


def summarize_plan(plan: dict) -> dict:
    return {
        "success": bool(plan.get("success", False)),
        "source": plan.get("source"),
        "status": str(plan.get("status")),
        "num_positions": len(plan.get("positions", [])),
        "target_pose_world": plan.get("target_pose_world"),
    }


def save_episode_result(
    *,
    output_dir: Path,
    ep: int,
    args,
    initial_cup_pose,
    final_cup_pose,
    pickup_plan: dict,
    place_plan: dict,
    pickup_target_robot,
    place_target_robot,
    trajectory_files: dict,
):
    basic_validation = validate_episode_basic(
        initial_cup_pose=initial_cup_pose,
        final_cup_pose=final_cup_pose,
    )

    result = {
        "episode": ep,
        "cup_path": args.cup_path,
        "ee_path": args.ee_path,
        "observation_source": args.observation_source,
        "rgbd_observation_npz": args.rgbd_observation_npz,
        "grasp_mode": args.grasp_mode,
        "curobo_mode": args.curobo_mode,
        "execution_mode": args.execution_mode,
        "attach_cup_during_place": bool(args.attach_cup_during_place),
        "target_source": getattr(args, "target_source", "manual"),
        "graspnet_target_key": getattr(args, "graspnet_target_key", None),
        "place_offset_robot": [float(x) for x in getattr(args, "place_offset_robot", [0.0, 0.0, 0.0])],
        "pickup_target_robot_xyz": pose_translation_from_matrix(pickup_target_robot),
        "place_target_robot_xyz": pose_translation_from_matrix(place_target_robot),
        "pickup_target_robot_matrix": matrix_to_list(pickup_target_robot),
        "place_target_robot_matrix": matrix_to_list(place_target_robot),
        "initial_cup_pose": matrix_to_list(initial_cup_pose),
        "initial_cup_xyz": pose_translation_from_matrix(initial_cup_pose),
        "final_cup_pose": matrix_to_list(final_cup_pose),
        "final_cup_xyz": pose_translation_from_matrix(final_cup_pose),
        "pickup_plan": summarize_plan(pickup_plan),
        "place_plan": summarize_plan(place_plan),
        "success": bool(
            safe_plan_success(pickup_plan)
            and safe_plan_success(place_plan)
            and basic_validation["success"]
        ),
        "basic_validation": basic_validation,
        "trajectory_files": trajectory_files,
    }

    out_path = output_dir / f"ep_{ep:04d}_episode_result.json"
    save_json(out_path, result)
    print(f"[SAVE] episode result: {out_path}", flush=True)

    return result

def save_collection_summary(output_dir: Path):
    """
    Summarize all ep_*_episode_result.json files in output_dir.
    """
    episodes = []

    for p in sorted(output_dir.glob("ep_*_episode_result.json")):
        try:
            d = json.loads(p.read_text(encoding="utf-8"))
        except Exception as e:
            episodes.append({
                "file": str(p),
                "load_error": repr(e),
                "success": False,
            })
            continue

        episodes.append({
            "file": str(p),
            "episode": d.get("episode"),
            "success": bool(d.get("success", False)),
            "initial_cup_xyz": d.get("initial_cup_xyz"),
            "final_cup_xyz": d.get("final_cup_xyz"),
            "basic_validation": d.get("basic_validation"),
            "pickup_plan": d.get("pickup_plan"),
            "place_plan": d.get("place_plan"),
            "trajectory_files": d.get("trajectory_files"),
        })

    num_episodes = len(episodes)
    num_success = sum(1 for e in episodes if e.get("success"))

    summary = {
        "output_dir": str(output_dir),
        "num_episodes": num_episodes,
        "num_success": num_success,
        "num_failed": num_episodes - num_success,
        "success_rate": float(num_success / num_episodes) if num_episodes else 0.0,
        "episodes": episodes,
    }

    out_path = output_dir / "summary.json"
    save_json(out_path, summary)

    print("[SAVE] collection summary:", out_path, flush=True)
    print(
        f"[SUMMARY] success rate: {num_success}/{num_episodes} = "
        f"{summary['success_rate']:.2%}",
        flush=True,
    )

    return summary

def load_retract_robot_state(robot_config_path: str | None) -> dict:
    """
    Temporary bring-up robot_state.

    This reads cuRobo cspace.joint_names and retract_config from the robot yaml.
    Later this should be replaced by the real IsaacLab robot joint state.
    """
    if robot_config_path is None:
        return {}

    cfg_path = Path(robot_config_path).expanduser().resolve()
    if not cfg_path.exists():
        return {}

    cfg = yaml.safe_load(cfg_path.read_text(encoding="utf-8"))
    cspace = cfg["robot_cfg"]["kinematics"]["cspace"]

    return {
        "joint_names": list(cspace["joint_names"]),
        "positions": [float(x) for x in cspace["retract_config"]],
    }


def pose_matrix_to_world_position(pose_world: np.ndarray) -> np.ndarray:
    """
    Extract world position from the current USD/Gf-style 4x4 matrix.

    In this project:
    - USD world translation is in row 3: m[3, 0:3].
    - mock GraspNet adds approach/grasp/lift offsets in column 3.
    """
    m = np.asarray(pose_world, dtype=float)

    row_t = m[3, 0:3].copy()
    col_t = m[0:3, 3].copy()

    if np.linalg.norm(row_t) > 1e-8:
        return row_t + col_t

    return col_t


def world_position_to_robot_position(
    position_world: np.ndarray,
    robot_world: np.ndarray,
) -> np.ndarray:
    """
    USD/Gf row-vector convention:
        p_world_h = p_robot_h @ T_world_robot
        p_robot_h = p_world_h @ inv(T_world_robot)
    """
    p = np.asarray(position_world, dtype=float)
    t_robot = np.asarray(robot_world, dtype=float)

    p_h = np.array([p[0], p[1], p[2], 1.0], dtype=float)
    p_robot_h = p_h @ np.linalg.inv(t_robot)

    return p_robot_h[0:3]


def make_robot_frame_target_matrix(
    pose_world: np.ndarray,
    robot_world: np.ndarray,
    *,
    fixed_orientation: bool = True,
    clamp_to_known_reachable: bool = True,
) -> np.ndarray:
    """
    Convert a world-frame target matrix into a robot-frame target matrix.

    For bring-up, we clamp to a known reachable target:
        [0.45, 0.0, 0.8]
    because cuRobo reachability scan showed this target succeeds.

    In this script, we intentionally keep this helper stable and then override
    pickup/place xyz later using:
        override_robot_frame_target_translation(...)
    """
    position_world = pose_matrix_to_world_position(pose_world)
    position_robot = world_position_to_robot_position(position_world, robot_world)

    if clamp_to_known_reachable:
        position_robot[0] = 0.45
        position_robot[1] = 0.0
        position_robot[2] = 0.80

    target_robot = np.eye(4, dtype=float)

    if not fixed_orientation:
        # Disabled for now: current USD matrices contain scale.
        target_robot[0:3, 0:3] = np.asarray(pose_world, dtype=float)[0:3, 0:3]

    # Row-vector convention: translation is in row 3.
    target_robot[3, 0:3] = position_robot

    return target_robot


def override_robot_frame_target_translation(
    target_robot: np.ndarray,
    xyz,
    *,
    name: str,
) -> np.ndarray:
    """
    Override only the translation part of a 4x4 robot-frame target matrix.

    This is the key bring-up change:
    - make_robot_frame_target_matrix(...) still creates a stable reachable matrix.
    - This function then makes pickup and place use different xyz targets.

    Row-vector convention:
        target_robot[3, 0:3] = [x, y, z]
    """
    target_robot = np.asarray(target_robot, dtype=float).copy()
    xyz = np.asarray(xyz, dtype=float)

    if target_robot.shape != (4, 4):
        raise ValueError(f"{name} target_robot must be 4x4, got {target_robot.shape}")

    if xyz.shape != (3,):
        raise ValueError(f"{name} xyz must have shape (3,), got {xyz.shape}")

    if not np.isfinite(xyz).all():
        raise ValueError(f"{name} xyz contains NaN/Inf: {xyz}")

    target_robot[3, 0:3] = xyz

    print(f"[TARGET] {name} robot-frame xyz override: {xyz.tolist()}", flush=True)
    print(f"[TARGET] {name} target robot-frame matrix after override:", flush=True)
    print(target_robot, flush=True)

    return target_robot



def make_robot_frame_target_from_world_pose(
    pose_world: np.ndarray,
    robot_world: np.ndarray,
    *,
    fixed_orientation: bool = True,
    force_z: float | None = None,
) -> np.ndarray:
    """
    Convert a GraspNet/world pose to a cuRobo robot-frame target matrix.

    Unlike make_robot_frame_target_matrix(..., clamp_to_known_reachable=True),
    this function DOES NOT clamp to a fixed reachable point. This is the key
    function for GraspNet-driven pickup target generation.
    """
    position_world = pose_matrix_to_world_position(pose_world)
    position_robot = world_position_to_robot_position(position_world, robot_world)

    if force_z is not None:
        position_robot[2] = float(force_z)

    target_robot = np.eye(4, dtype=float)

    if not fixed_orientation:
        target_robot[0:3, 0:3] = np.asarray(pose_world, dtype=float)[0:3, 0:3]

    target_robot[3, 0:3] = position_robot

    print("[TARGET_GRASPNET] world xyz:", position_world.tolist(), flush=True)
    print("[TARGET_GRASPNET] robot xyz:", position_robot.tolist(), flush=True)
    print("[TARGET_GRASPNET] target robot matrix:", flush=True)
    print(target_robot, flush=True)

    return target_robot


def select_grasp_pose_world(grasp_result: dict, preferred_key: str):
    """
    Select a pose from grasp_result.

    The real GraspNet service should ideally return one or more of:
      - lift_pose_world
      - grasp_pose_world
      - approach_pose_world

    We prefer lift_pose_world because the current pickup replay attaches the cup
    after reaching pickup. If real GraspNet only returns grasp_pose_world, this
    function will fall back to it.
    """
    candidates = []

    if preferred_key:
        candidates.append(preferred_key)

    candidates.extend([
        "lift_pose_world",
        "grasp_pose_world",
        "approach_pose_world",
        "target_pose_world",
    ])

    seen = set()
    ordered = []
    for k in candidates:
        if k not in seen:
            ordered.append(k)
            seen.add(k)

    for key in ordered:
        if key in grasp_result:
            pose = np.asarray(grasp_result[key], dtype=float)
            if pose.shape != (4, 4):
                raise ValueError(
                    f"grasp_result[{key!r}] must be 4x4, got shape={pose.shape}"
                )
            return key, pose

    raise KeyError(
        "Cannot find a usable pose in grasp_result. "
        f"Available keys: {list(grasp_result.keys())}"
    )


def make_targets_from_graspnet_result(
    *,
    grasp_result: dict,
    robot_world: np.ndarray,
    preferred_key: str,
    place_offset_robot,
    pickup_target_z: float | None = None,
    place_target_z: float | None = None,
):
    """
    GraspNet-driven target generation.

    pickup target:
        selected GraspNet pose in world frame -> robot frame

    place target:
        pickup target + robot-frame offset, usually [0, 0.10, 0]
    """
    key, pose_world = select_grasp_pose_world(grasp_result, preferred_key)

    print("[TARGET_GRASPNET] selected pose key:", key, flush=True)
    print("[TARGET_GRASPNET] selected pose world:", flush=True)
    print(pose_world, flush=True)

    pickup_target_robot = make_robot_frame_target_from_world_pose(
        pose_world,
        robot_world,
        fixed_orientation=True,
        force_z=pickup_target_z,
    )

    place_offset_robot = np.asarray(place_offset_robot, dtype=float)
    if place_offset_robot.shape != (3,):
        raise ValueError(f"place_offset_robot must be shape (3,), got {place_offset_robot.shape}")

    place_target_robot = np.asarray(pickup_target_robot, dtype=float).copy()
    place_target_robot[3, 0:3] = (
        place_target_robot[3, 0:3] + place_offset_robot
    )

    if place_target_z is not None:
        place_target_robot[3, 2] = float(place_target_z)

    print("[TARGET_GRASPNET] place offset robot:", place_offset_robot.tolist(), flush=True)
    print("[TARGET_GRASPNET] pickup target robot xyz:", pickup_target_robot[3, 0:3].tolist(), flush=True)
    print("[TARGET_GRASPNET] place target robot xyz:", place_target_robot[3, 0:3].tolist(), flush=True)

    return pickup_target_robot, place_target_robot


def make_auto_targets_from_cup_pose(
    *,
    cup_pose_world: np.ndarray,
    robot_world: np.ndarray,
    place_offset_robot,
    pickup_z: float = 0.80,
    place_z: float = 0.85,
):
    """
    Cup-pose-driven target generation.

    This is not GraspNet. It uses the current cup pose:
        cup world xyz -> cup robot xyz
        pickup = [cup_robot_x, cup_robot_y, pickup_z]
        place  = pickup + place_offset_robot, with z=place_z
    """
    cup_pose_world = np.asarray(cup_pose_world, dtype=float)
    robot_world = np.asarray(robot_world, dtype=float)

    cup_world_xyz = cup_pose_world[3, 0:3].copy()
    cup_robot_xyz = world_position_to_robot_position(cup_world_xyz, robot_world)

    place_offset_robot = np.asarray(place_offset_robot, dtype=float)
    if place_offset_robot.shape != (3,):
        raise ValueError(f"place_offset_robot must be shape (3,), got {place_offset_robot.shape}")

    pickup_target_robot = np.eye(4, dtype=float)
    pickup_target_robot[3, 0:3] = [
        float(cup_robot_xyz[0]),
        float(cup_robot_xyz[1]),
        float(pickup_z),
    ]

    place_target_robot = np.eye(4, dtype=float)
    place_target_robot[3, 0:3] = pickup_target_robot[3, 0:3] + place_offset_robot
    place_target_robot[3, 2] = float(place_z)

    print("[TARGET_AUTO] cup world xyz:", cup_world_xyz.tolist(), flush=True)
    print("[TARGET_AUTO] cup robot xyz:", cup_robot_xyz.tolist(), flush=True)
    print("[TARGET_AUTO] pickup target robot xyz:", pickup_target_robot[3, 0:3].tolist(), flush=True)
    print("[TARGET_AUTO] place offset robot:", place_offset_robot.tolist(), flush=True)
    print("[TARGET_AUTO] place target robot xyz:", place_target_robot[3, 0:3].tolist(), flush=True)

    return pickup_target_robot, place_target_robot


def make_place_pose(current_pose: np.ndarray, *, axis: str, distance: float) -> np.ndarray:
    """
    Move the object in USD row-vector convention.
    Translation is pose[3, 0:3], not pose[0:3, 3].

    This is still useful for debug_object mode. In a2d_replay mode, the actual
    cuRobo place target is now controlled by --place-target-robot.
    """
    pose = np.asarray(current_pose, dtype=float).copy()

    if axis == "x":
        pose[3, 0] += distance
    else:
        pose[3, 1] += distance

    return pose


def save_synthetic_observation_npz(
    path: Path,
    *,
    cup_pose_world: np.ndarray,
    num_points: int = 2048,
):
    """
    Temporary observation file for testing GraspNet real-mode plumbing.

    This is not real RGB-D. It only creates a point cloud-like npz so that
    graspnet_service.py --mode real skeleton can verify file input.
    """
    path.parent.mkdir(parents=True, exist_ok=True)

    cup_center = np.asarray(cup_pose_world, dtype=float)[3, 0:3]
    points = cup_center[None, :] + 0.02 * np.random.randn(num_points, 3)
    colors = np.ones((num_points, 3), dtype=np.float32)

    np.savez(
        path,
        points=points.astype(np.float32),
        colors=colors.astype(np.float32),
        object_pose_world=np.asarray(cup_pose_world, dtype=np.float32),
    )


def save_observation_from_existing_rgbd_npz(src_npz_path, dst_npz_path):
    """
    Copy an existing RGB-D observation npz into the episode observation path.

    This is an adapter layer:
      src: RGB-D exporter output
      dst: current GraspNet skeleton expected observation path

    Required fields:
      points: [N, 3], float32
      colors: [N, 3], float32, range 0~1
    """
    src_npz_path = Path(src_npz_path)
    dst_npz_path = Path(dst_npz_path)

    if not src_npz_path.exists():
        raise FileNotFoundError(f"RGB-D observation npz not found: {src_npz_path}")

    obs = np.load(src_npz_path, allow_pickle=True)

    if "points" not in obs.files or "colors" not in obs.files:
        raise KeyError(
            f"RGB-D observation must contain 'points' and 'colors'. "
            f"Available keys: {obs.files}"
        )

    points = obs["points"].astype(np.float32)
    colors = obs["colors"].astype(np.float32)

    if points.ndim != 2 or points.shape[1] != 3:
        raise ValueError(f"Invalid points shape: {points.shape}")

    if colors.ndim != 2 or colors.shape[1] != 3:
        raise ValueError(f"Invalid colors shape: {colors.shape}")

    if points.shape[0] != colors.shape[0]:
        raise ValueError(
            f"points/colors count mismatch: {points.shape[0]} vs {colors.shape[0]}"
        )

    if not np.isfinite(points).all():
        raise ValueError("points contain NaN/Inf")

    if not np.isfinite(colors).all():
        raise ValueError("colors contain NaN/Inf")

    dst_npz_path.parent.mkdir(parents=True, exist_ok=True)

    save_dict = {
        "points": points,
        "colors": colors,
    }

    for k in [
        "rgb",
        "depth",
        "intrinsics",
        "points_camera",
        "valid_depth_mask",
        "target_xyz",
        "camera_position",
        "camera_path",
        "target_path",
        "scene_usd",
        "depth_source",
    ]:
        if k in obs.files:
            save_dict[k] = obs[k]

    np.savez_compressed(dst_npz_path, **save_dict)

    print(f"[OBS] copied RGB-D observation", flush=True)
    print(f"[OBS] src: {src_npz_path}", flush=True)
    print(f"[OBS] dst: {dst_npz_path}", flush=True)
    print(f"[OBS] points: {points.shape} {points.dtype}", flush=True)
    print(f"[OBS] colors: {colors.shape} {colors.dtype}", flush=True)
    print(f"[OBS] points min: {points.min(axis=0)}", flush=True)
    print(f"[OBS] points max: {points.max(axis=0)}", flush=True)
    print(f"[OBS] colors min/max: {colors.min()} / {colors.max()}", flush=True)


def execute_cartesian_debug_on_object(
    *,
    simulation_app,
    stage,
    cup_path: str,
    target_pose_world: np.ndarray,
    frames: int,
):
    """
    Debug execution: directly move cup.

    This is not final robot execution.

    Final execution should be:
    - cuRobo returns joint trajectory
    - A2D Articulation executes joint trajectory
    - close gripper
    - attach / physics grasp
    """
    from isaac_collector.runtime.load_scene import (
