from __future__ import annotations

import argparse
import json
import os
import sys
from contextlib import redirect_stdout
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

import numpy as np


def send(obj: Dict[str, Any]):
    sys.stdout.write(json.dumps(obj) + "\n")
    sys.stdout.flush()


def _as_float_matrix4(x: Any) -> np.ndarray:
    m = np.asarray(x, dtype=np.float64)
    if m.shape != (4, 4):
        raise ValueError(f"Expected 4x4 matrix, got shape={m.shape}")
    return m


def _matrix_to_row_translation_pose(rotation: np.ndarray, translation: np.ndarray) -> List[List[float]]:
    """
    Return a USD/Gf-style matrix used by the current runner:
    - rotation in upper-left 3x3
    - translation in row 3, columns 0:3
    - last column remains [0,0,0,1]^T
    """
    T = np.eye(4, dtype=np.float64)
    T[:3, :3] = np.asarray(rotation, dtype=np.float64).reshape(3, 3)
    T[3, 0:3] = np.asarray(translation, dtype=np.float64).reshape(3)
    return T.tolist()


def _make_offset_pose_row(T: np.ndarray, dz: float) -> List[List[float]]:
    out = np.asarray(T, dtype=np.float64).copy()
    out[3, 2] += float(dz)
    return out.tolist()


class GraspNetService:
    def __init__(self, *, mode: str, checkpoint: str | None):
        self.mode = mode
        self.checkpoint = checkpoint

        print(f"[GraspNetService] python: {sys.executable}", file=sys.stderr)
        print(f"[GraspNetService] mode: {mode}", file=sys.stderr)
        print(f"[GraspNetService] checkpoint: {checkpoint}", file=sys.stderr)

        self.model = None
        self.device = None
        self.torch = None
        self.pred_decode = None
        self.GraspGroup = None

        if self.mode == "real":
            if checkpoint is None or not Path(checkpoint).exists():
                raise FileNotFoundError(
                    f"Real GraspNet needs checkpoint, but got: {checkpoint}"
                )
            self._load_real_model()
        else:
            self.model = None

    # ---------------------------------------------------------------------
    # Real GraspNet loading
    # ---------------------------------------------------------------------
    def _find_graspnet_root(self) -> Path:
        """
        Try to locate graspnet-baseline.

        Priority:
        1. GRASPNET_BASELINE_ROOT env var
        2. /home/pm/Desktop/Project/robot_stack/third_party/graspnet-baseline
        3. /home/pm/Desktop/Project/graspnet-baseline
        4. parent folders near checkpoint
        """
        candidates = []

        env_root = os.environ.get("GRASPNET_BASELINE_ROOT")
        if env_root:
            candidates.append(Path(env_root))

        here = Path(__file__).resolve()
        repo_root = here.parents[2]  # robot_stack
        candidates.append(repo_root / "third_party" / "graspnet-baseline")
        candidates.append(Path("/home/pm/Desktop/Project/graspnet-baseline"))

        ckpt = Path(self.checkpoint).resolve()
        for p in [ckpt.parent, *ckpt.parents]:
            if p.name == "graspnet-baseline":
                candidates.append(p)
            if (p / "models" / "graspnet.py").exists():
                candidates.append(p)

        for c in candidates:
            if c and (c / "models" / "graspnet.py").exists():
                return c.resolve()

        raise FileNotFoundError(
            "Cannot find graspnet-baseline root. "
            "Please set GRASPNET_BASELINE_ROOT=/path/to/graspnet-baseline. "
            f"Tried: {[str(c) for c in candidates]}"
        )

    def _load_real_model(self):
        """
        Load real GraspNet baseline model.

        Expected repo layout:
          graspnet-baseline/
            models/graspnet.py
            graspnetAPI/
            ...

        Expected checkpoint:
          logs/log_rs/checkpoint.tar
        """
        import torch

        self.torch = torch
        self.device = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")

        graspnet_root = self._find_graspnet_root()
        print(f"[GraspNetService] graspnet_root: {graspnet_root}", file=sys.stderr)

        # Put graspnet-baseline repo first, because its imports are relative-style:
        #   from models.graspnet import GraspNet, pred_decode
        sys.path.insert(0, str(graspnet_root))

        try:
            from models.graspnet import GraspNet, pred_decode
        except Exception as e:
            raise ImportError(
                "Failed to import GraspNet from graspnet-baseline. "
                "Make sure you run this service inside graspnet_env and that "
                "pointnet2/knn extensions were compiled correctly."
            ) from e

        try:
            from graspnetAPI import GraspGroup
        except Exception as e:
            raise ImportError(
                "Failed to import graspnetAPI.GraspGroup. "
                "Install graspnetAPI in graspnet_env or make sure it is available."
            ) from e

        print("[GraspNetService] constructing GraspNet model...", file=sys.stderr)

        # Standard GraspNet baseline config.
        model = GraspNet(
            input_feature_dim=0,
            num_view=300,
            num_angle=12,
            num_depth=4,
            cylinder_radius=0.05,
            hmin=-0.02,
            hmax_list=[0.01, 0.02, 0.03, 0.04],
            is_training=False,
        )

        model.to(self.device)

        print(f"[GraspNetService] loading checkpoint: {self.checkpoint}", file=sys.stderr)
        ckpt = torch.load(self.checkpoint, map_location=self.device)

        if isinstance(ckpt, dict) and "model_state_dict" in ckpt:
            state = ckpt["model_state_dict"]
        elif isinstance(ckpt, dict) and "state_dict" in ckpt:
            state = ckpt["state_dict"]
        else:
            state = ckpt

        model.load_state_dict(state, strict=False)
        model.eval()

        self.model = model
        self.pred_decode = pred_decode
        self.GraspGroup = GraspGroup

        print("[GraspNetService] real GraspNet model loaded.", file=sys.stderr)

    # ---------------------------------------------------------------------
    # Public predict
    # ---------------------------------------------------------------------
    def predict(self, params: Dict[str, Any]) -> Dict[str, Any]:
        if self.mode == "mock":
            return self._mock_predict(params)
        return self._real_predict(params)

    def _mock_predict(self, params: Dict[str, Any]) -> Dict[str, Any]:
        object_pose = _as_float_matrix4(params["object_pose_world"])

        # Current project mostly uses row-translation USD/Gf matrices.
        # Use row translation if it is nonzero, otherwise column translation.
        row_t = object_pose[3, 0:3]
        col_t = object_pose[0:3, 3]
        center = row_t if np.linalg.norm(row_t) >= np.linalg.norm(col_t) else col_t

        R = np.eye(3, dtype=np.float64)
        grasp_T = np.eye(4, dtype=np.float64)
        grasp_T[:3, :3] = R
        grasp_T[3, 0:3] = center + np.array([0.0, 0.0, 0.08], dtype=np.float64)

        pregrasp_T = grasp_T.copy()
        pregrasp_T[3, 2] += 0.20

        lift_T = grasp_T.copy()
        lift_T[3, 2] += 0.35

        return {
            "source": "mock_graspnet",
            "score": 1.0,
            "width": 0.06,
            "pregrasp_pose_world": pregrasp_T.tolist(),
            "grasp_pose_world": grasp_T.tolist(),
            "lift_pose_world": lift_T.tolist(),
            "candidates": [
                {
                    "rank": 0,
                    "score": 1.0,
                    "width": 0.06,
                    "pregrasp_pose_world": pregrasp_T.tolist(),
                    "grasp_pose_world": grasp_T.tolist(),
                    "lift_pose_world": lift_T.tolist(),
                }
            ],
        }

    # ---------------------------------------------------------------------
    # Input point cloud
    # ---------------------------------------------------------------------
    def _load_points_from_npz(self, obs_path: Path) -> Tuple[np.ndarray, Optional[np.ndarray]]:
        if not obs_path.exists():
            raise FileNotFoundError(f"observation_npz not found: {obs_path}")

        data = np.load(obs_path, allow_pickle=True)
        keys = list(data.keys())

        print("[GraspNetService] loaded observation_npz:", obs_path, file=sys.stderr)
        print("[GraspNetService] observation keys:", keys, file=sys.stderr)

        points = None
        for k in ["points", "point_cloud", "cloud", "xyz", "point_cloud_world", "points_world"]:
            if k in data:
                points = np.asarray(data[k], dtype=np.float32)
                print(f"[GraspNetService] using points key: {k}", file=sys.stderr)
                break

        if points is None:
            raise KeyError(
                f"Cannot find point cloud in npz. Available keys={keys}. "
                "Expected one of: points, point_cloud, cloud, xyz, point_cloud_world, points_world."
            )

        if points.ndim != 2 or points.shape[1] < 3:
            raise ValueError(f"points must be [N, >=3], got shape={points.shape}")

        points = points[:, :3].astype(np.float32)

        colors = None
        for k in ["colors", "rgb", "color", "point_colors"]:
            if k in data:
                colors = np.asarray(data[k], dtype=np.float32)
                if colors.ndim == 2 and colors.shape[1] >= 3 and colors.shape[0] == points.shape[0]:
                    colors = colors[:, :3]
                    if colors.max() > 1.5:
                        colors = colors / 255.0
                    print(f"[GraspNetService] using colors key: {k}", file=sys.stderr)
                else:
                    colors = None
                break

        # Remove invalid points.
        valid = np.isfinite(points).all(axis=1)
        points = points[valid]
        if colors is not None:
            colors = colors[valid]

        if points.shape[0] < 50:
            raise ValueError(f"Too few valid points for GraspNet: {points.shape[0]}")

        return points, colors

    def _sample_points(self, points: np.ndarray, num_point: int = 20000) -> np.ndarray:
        n = points.shape[0]
        if n >= num_point:
            idx = np.random.choice(n, num_point, replace=False)
        else:
            idx1 = np.arange(n)
            idx2 = np.random.choice(n, num_point - n, replace=True)
            idx = np.concatenate([idx1, idx2], axis=0)
        return points[idx].astype(np.float32)

    # ---------------------------------------------------------------------
    # Real inference
    # ---------------------------------------------------------------------
    def _real_predict(self, params: Dict[str, Any]) -> Dict[str, Any]:
        """
        Real GraspNet inference.

        Required:
        - observation_npz: npz containing object/scene point cloud.
          Current Isaac exporter usually stores key "points".

        Optional:
        - max_candidates: default 50
        - num_point: default 20000
        - min_score: optional score filter
        """
        if self.model is None:
            raise RuntimeError("Real GraspNet model is not loaded.")

        torch = self.torch
        obs_path = params.get("observation_npz")
        if obs_path is None:
            raise ValueError("Real GraspNet requires observation_npz.")

        obs_path = Path(obs_path)
        points, colors = self._load_points_from_npz(obs_path)

        num_point = int(params.get("num_point", 20000))
        max_candidates = int(params.get("max_candidates", 50))
        min_score = params.get("min_score", None)
        min_score = None if min_score is None else float(min_score)

        cloud_sampled = self._sample_points(points, num_point=num_point)

        end_points = {
            "point_clouds": torch.from_numpy(cloud_sampled[None, :, :]).to(
                self.device, dtype=torch.float32
            )
        }

        print(
            f"[GraspNetService] running real inference: points={points.shape}, sampled={cloud_sampled.shape}",
            file=sys.stderr,
        )

        with torch.no_grad():
            end_points = self.model(end_points)
            grasp_preds = self.pred_decode(end_points)

        # GraspNet baseline pred_decode returns a list, batch size = 1.
        gg_array = grasp_preds[0].detach().cpu().numpy()
        gg = self.GraspGroup(gg_array)

        # Standard post-process.
        try:
            gg = gg.nms()
        except Exception as e:
            print(f"[GraspNetService][WARN] GraspGroup.nms failed: {repr(e)}", file=sys.stderr)

        try:
            gg = gg.sort_by_score()
        except Exception as e:
            print(f"[GraspNetService][WARN] GraspGroup.sort_by_score failed: {repr(e)}", file=sys.stderr)

        candidates = self._graspgroup_to_candidates(
            gg,
            max_candidates=max_candidates,
            min_score=min_score,
        )

        if not candidates:
            return {
                "source": "real_graspnet",
                "success": False,
                "error": "no grasp candidates returned",
                "num_input_points": int(points.shape[0]),
                "num_sampled_points": int(cloud_sampled.shape[0]),
                "candidates": [],
            }

        top = candidates[0]

        return {
            "source": "real_graspnet",
            "success": True,
            "num_input_points": int(points.shape[0]),
            "num_sampled_points": int(cloud_sampled.shape[0]),
            "num_candidates": len(candidates),

            # Backward-compatible top-1 fields:
            "score": top["score"],
            "width": top["width"],
            "pregrasp_pose_world": top["pregrasp_pose_world"],
            "grasp_pose_world": top["grasp_pose_world"],
            "lift_pose_world": top["lift_pose_world"],

            # New multi-candidate output:
            "candidates": candidates,
        }

    def _get_grasp_attr(self, g: Any, names: List[str], default: Any = None) -> Any:
        for name in names:
            if hasattr(g, name):
                value = getattr(g, name)
                if callable(value):
                    try:
                        value = value()
                    except TypeError:
                        pass
                return value
        return default

    def _graspgroup_to_candidates(
        self,
        gg: Any,
        *,
        max_candidates: int,
        min_score: Optional[float],
    ) -> List[Dict[str, Any]]:
        candidates: List[Dict[str, Any]] = []

        n = len(gg)
        take = min(int(n), int(max_candidates))
        print(f"[GraspNetService] decoded grasps: {n}, taking: {take}", file=sys.stderr)

        for i in range(take):
            g = gg[i]

            score = self._get_grasp_attr(g, ["score"], default=None)
            width = self._get_grasp_attr(g, ["width"], default=None)
            translation = self._get_grasp_attr(g, ["translation"], default=None)
            rotation = self._get_grasp_attr(g, ["rotation_matrix"], default=None)
            depth = self._get_grasp_attr(g, ["depth"], default=None)

            # Fallback for GraspGroup vectorized properties.
            if score is None and hasattr(gg, "scores"):
                score = gg.scores[i]
            if width is None and hasattr(gg, "widths"):
                width = gg.widths[i]
            if translation is None and hasattr(gg, "translations"):
                translation = gg.translations[i]
            if rotation is None and hasattr(gg, "rotation_matrices"):
                rotation = gg.rotation_matrices[i]
            if depth is None and hasattr(gg, "depths"):
                depth = gg.depths[i]

            score = float(score) if score is not None else 0.0
            width = float(width) if width is not None else 0.06
            depth = float(depth) if depth is not None else 0.0

            if min_score is not None and score < min_score:
                continue

            if translation is None or rotation is None:
                print(
                    f"[GraspNetService][WARN] skip grasp {i}: missing translation or rotation",
                    file=sys.stderr,
                )
                continue

            translation = np.asarray(translation, dtype=np.float64).reshape(3)
            rotation = np.asarray(rotation, dtype=np.float64).reshape(3, 3)

            grasp_T = np.eye(4, dtype=np.float64)
            grasp_T[:3, :3] = rotation
            grasp_T[3, 0:3] = translation

            # Simple vertical pregrasp/lift for current runner.
            # Later you can change this to offset along the GraspNet approach axis.
            pregrasp_T = grasp_T.copy()
            pregrasp_T[3, 2] += 0.20

            lift_T = grasp_T.copy()
            lift_T[3, 2] += 0.35

            candidates.append(
                {
                    "rank": len(candidates),
                    "score": score,
                    "width": width,
                    "depth": depth,
                    "translation_world": translation.tolist(),
                    "rotation_world": rotation.tolist(),
                    "pregrasp_pose_world": pregrasp_T.tolist(),
                    "grasp_pose_world": grasp_T.tolist(),
                    "lift_pose_world": lift_T.tolist(),
                }
            )

        return candidates


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--mode", choices=["mock", "real"], default="mock")
    parser.add_argument("--checkpoint", default=None)
    args = parser.parse_args()

    try:
        # Redirect noisy imports/model construction logs to stderr.
        with redirect_stdout(sys.stderr):
            service = GraspNetService(mode=args.mode, checkpoint=args.checkpoint)

        send({
            "type": "ready",
            "service": "graspnet",
            "python": sys.executable,
            "mode": args.mode,
        })
    except Exception as e:
        send({
            "type": "ready",
            "service": "graspnet",
            "error": repr(e),
        })
        raise

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue

        req = json.loads(line)
        req_id = req.get("id")
        method = req.get("method")
        params = req.get("params", {})

        if method == "shutdown":
            send({"id": req_id, "success": True, "result": {"shutdown": True}})
            break

        try:
            if method == "predict":
                with redirect_stdout(sys.stderr):
                    result = service.predict(params)
            else:
                raise ValueError(f"Unknown method: {method}")

            send({
                "id": req_id,
                "success": True,
                "result": result,
            })

        except Exception as e:
            send({
                "id": req_id,
                "success": False,
                "error": repr(e),
            })


if __name__ == "__main__":
    main()