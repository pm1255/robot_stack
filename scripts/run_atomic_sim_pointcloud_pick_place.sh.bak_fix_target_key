#!/usr/bin/env bash
set -euo pipefail

cd /home/pm/Desktop/Project/robot_stack

python -u isaac_collector/run_atomic_manipulation.py \
  --scene-usd /home/pm/Desktop/Project/house_type_usd/mutil_room/mutil_room001.usd \
  --scene-registry-json /home/pm/Desktop/Project/robot_stack/isaac_collector/configs/scenes/mutil_room001.json \
  --task-json /home/pm/Desktop/Project/robot_stack/configs/tasks/pick_place_cup_right10cm.json \
  --observation-mode sim_object_pointcloud \
  --target-cloud-npoints 20000 \
  --grasp-mode real \
  --graspnet-checkpoint /home/pm/Desktop/Project/robot_stack/third_party/graspnet-baseline/logs/log_rs/checkpoint.tar \
  --curobo-mode real \
  --curobo-robot-config /home/pm/Desktop/Project/robot_stack/configs/curobo/a2d_wholebody_ignore_adjacent.yml \
  --execution-mode a2d_replay \
  --attach-target-during-place \
  --save-executed-trajectory \
  --output-dir /tmp/robot_pipeline/atomic_manipulation \
  --headless \
  2>&1 | tee /tmp/run_atomic_sim_pointcloud_pick_place.log
